# Omni Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# DATABASE (from Neon Console)
# ===========================================
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# ===========================================
# NEON AUTH (enable in Neon Console first!)
# ===========================================
# Get this from: Neon Console > Your Project > Auth > Enable > Copy URL
NEON_AUTH_URL=https://your-project.neonauth.us-east-1.aws.neon.tech/neondb/auth

# ===========================================
# AUTH SECRET (generate with: openssl rand -base64 32)
# ===========================================
AUTH_SECRET=generate-a-32-character-secret-here

# ===========================================
# OPTIONAL: For client-side
# ===========================================
# NEXT_PUBLIC_API_URL=http://localhost:3000
